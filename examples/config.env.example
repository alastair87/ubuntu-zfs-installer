# Example config file for install-ubuntu-zfs.sh

DISK=/dev/disk/by-id/ata-example-disk
HOSTNAME_VALUE=zfs-host
USERNAME_VALUE=alice
# Generate with: openssl passwd -6
USER_PASSWORD_HASH=
UBUNTU_CODENAME=resolute
ENCRYPTION_MODE=luks
# Set to 0 to disable swap.
SWAP_SIZE=8G
BOOT_POOL_SIZE=2G
ESP_SIZE=512M
ENABLE_SSH=1
ENABLE_DESKTOP=0
FORCE=0
DRY_RUN=1
